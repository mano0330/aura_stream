# Database Connection URL (PostgreSQL)
# For local dev: postgresql://username:password@localhost:5432/database_name
# For Supabase: postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aura_stream?schema=public"

# JSON Web Token Secret
JWT_SECRET="super_secret_session_key_for_aura_stream_development_12345!"

# API Port Configuration
PORT=3001

# Allowed CORS origins (comma-separated list)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3002"
